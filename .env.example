# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
# Never paste your actual token into this file.

# Your Canvas API token (Settings → Approved Integrations → New Access Token)
CANVAS_TOKEN=your_token_here

# Your Canvas instance URL (no trailing slash)
CANVAS_BASE_URL=https://canvas.okstate.edu

# Your BIOL 1113 course ID (found in the Canvas course URL)
CANVAS_COURSE_ID=your_course_id_here

# Sandbox course ID — used by clean_sandbox.py only
CANVAS_SANDBOX_ID=your_sandbox_id_here
